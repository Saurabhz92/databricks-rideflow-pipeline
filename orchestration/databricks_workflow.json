{
  "name": "rideflow-realtime-pipeline",
  "description": "RideFlow Real-Time Ride Sharing Analytics Platform — Databricks Workflow",
  "email_notifications": {
    "on_failure": ["data-engineering-alerts@rideflow.com"],
    "no_alert_for_skipped_runs": true
  },
  "webhook_notifications": {},
  "timeout_seconds": 7200,
  "max_concurrent_runs": 1,
  "tasks": [
    {
      "task_key": "delta_table_init",
      "description": "Initialise all Bronze, Silver, Gold, Dead-Letter Delta tables (idempotent)",
      "notebook_task": {
        "notebook_path": "/Repos/rideflow-pipeline/scripts/init_tables",
        "base_parameters": {
          "action": "init"
        }
      },
      "job_cluster_key": "utility_cluster",
      "timeout_seconds": 300,
      "max_retries": 2,
      "retry_on_timeout": false
    },
    {
      "task_key": "bronze_streaming_ingestion",
      "description": "Start or ensure Bronze Kafka → Delta streaming pipeline is running",
      "depends_on": [{"task_key": "delta_table_init"}],
      "notebook_task": {
        "notebook_path": "/Repos/rideflow-pipeline/notebooks/bronze_streaming",
        "base_parameters": {
          "trigger_interval_ms": "30000",
          "max_offsets_per_trigger": "50000"
        }
      },
      "job_cluster_key": "streaming_cluster",
      "timeout_seconds": 3600,
      "max_retries": 3,
      "retry_on_timeout": true,
      "min_retry_interval_millis": 60000
    },
    {
      "task_key": "silver_streaming_transform",
      "description": "Silver layer: clean, deduplicate, MERGE to Silver Delta tables",
      "depends_on": [{"task_key": "bronze_streaming_ingestion"}],
      "notebook_task": {
        "notebook_path": "/Repos/rideflow-pipeline/notebooks/silver_streaming",
        "base_parameters": {
          "trigger_interval_ms": "30000"
        }
      },
      "job_cluster_key": "streaming_cluster",
      "timeout_seconds": 3600,
      "max_retries": 3,
      "retry_on_timeout": true,
      "min_retry_interval_millis": 60000
    },
    {
      "task_key": "gold_batch_aggregation",
      "description": "Gold layer: compute all business aggregations for the last 2 hours",
      "depends_on": [{"task_key": "silver_streaming_transform"}],
      "notebook_task": {
        "notebook_path": "/Repos/rideflow-pipeline/notebooks/gold_aggregations",
        "base_parameters": {
          "since_hours": "2"
        }
      },
      "job_cluster_key": "compute_cluster",
      "timeout_seconds": 1800,
      "max_retries": 2,
      "retry_on_timeout": false
    },
    {
      "task_key": "nightly_maintenance",
      "description": "OPTIMIZE, ZORDER, VACUUM all Delta tables — runs nightly",
      "depends_on": [{"task_key": "gold_batch_aggregation"}],
      "notebook_task": {
        "notebook_path": "/Repos/rideflow-pipeline/delta_utils/delta_tables_init",
        "base_parameters": {
          "action": "maintain",
          "retain_hours": "168"
        }
      },
      "job_cluster_key": "utility_cluster",
      "timeout_seconds": 3600,
      "max_retries": 1,
      "retry_on_timeout": false
    },
    {
      "task_key": "pipeline_monitoring",
      "description": "Run health checks, compute dead-letter rates, send Slack alerts",
      "depends_on": [{"task_key": "gold_batch_aggregation"}],
      "notebook_task": {
        "notebook_path": "/Repos/rideflow-pipeline/monitoring/run_monitoring",
        "base_parameters": {
          "duration_mins": "5"
        }
      },
      "job_cluster_key": "utility_cluster",
      "timeout_seconds": 600,
      "max_retries": 1,
      "retry_on_timeout": false
    }
  ],
  "job_clusters": [
    {
      "job_cluster_key": "streaming_cluster",
      "new_cluster": {
        "cluster_name": "rideflow-streaming",
        "spark_version": "14.3.x-scala2.12",
        "node_type_id": "m5.2xlarge",
        "num_workers": 4,
        "autoscale": {
          "min_workers": 2,
          "max_workers": 8
        },
        "spark_conf": {
          "spark.sql.extensions": "io.delta.sql.DeltaSparkSessionExtension",
          "spark.sql.catalog.spark_catalog": "org.apache.spark.sql.delta.catalog.DeltaCatalog",
          "spark.databricks.delta.optimizeWrite.enabled": "true",
          "spark.databricks.delta.autoCompact.enabled": "true",
          "spark.sql.shuffle.partitions": "200",
          "spark.streaming.backpressure.enabled": "true"
        },
        "spark_env_vars": {
          "PIPELINE_ENV": "prod",
          "KAFKA_BOOTSTRAP_SERVERS": "{{secrets/rideflow/kafka_bootstrap}}",
          "S3_BUCKET": "rideflow-lakehouse",
          "LOG_LEVEL": "INFO",
          "SLACK_WEBHOOK_URL": "{{secrets/rideflow/slack_webhook}}"
        },
        "aws_attributes": {
          "instance_profile_arn": "arn:aws:iam::123456789:instance-profile/rideflow-databricks-role",
          "availability": "SPOT_WITH_FALLBACK",
          "first_on_demand": 1,
          "spot_bid_price_percent": 80
        },
        "init_scripts": [
          {
            "s3": {
              "destination": "s3://rideflow-lakehouse/init-scripts/install-deps.sh"
            }
          }
        ]
      }
    },
    {
      "job_cluster_key": "compute_cluster",
      "new_cluster": {
        "cluster_name": "rideflow-gold-compute",
        "spark_version": "14.3.x-scala2.12",
        "node_type_id": "m5.xlarge",
        "num_workers": 2,
        "autoscale": {
          "min_workers": 1,
          "max_workers": 4
        },
        "spark_conf": {
          "spark.sql.extensions": "io.delta.sql.DeltaSparkSessionExtension",
          "spark.sql.catalog.spark_catalog": "org.apache.spark.sql.delta.catalog.DeltaCatalog",
          "spark.databricks.delta.optimizeWrite.enabled": "true"
        }
      }
    },
    {
      "job_cluster_key": "utility_cluster",
      "new_cluster": {
        "cluster_name": "rideflow-utility",
        "spark_version": "14.3.x-scala2.12",
        "node_type_id": "m5.large",
        "num_workers": 1,
        "spark_conf": {
          "spark.sql.extensions": "io.delta.sql.DeltaSparkSessionExtension",
          "spark.sql.catalog.spark_catalog": "org.apache.spark.sql.delta.catalog.DeltaCatalog"
        }
      }
    }
  ],
  "schedule": {
    "quartz_cron_expression": "0 0 * * * ?",
    "timezone_id": "UTC",
    "pause_status": "UNPAUSED"
  },
  "tags": {
    "team": "data-engineering",
    "project": "rideflow",
    "environment": "prod",
    "cost_center": "DE-001"
  }
}
